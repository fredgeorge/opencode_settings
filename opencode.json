{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3.6:27b-code-bf16-v2": {
          "name": "Qwen3.6 27B Dense bf16 V2 (main thinking/code model) - 54GB + 32K context",
          "tools": true,
          "reasoning": false
        },
        "qwen3-coder-next:q8.0": {
          "name": "Qwen3-Coder-Next 80B-A3B  (Q8, MoE, big coding model, no thinking) - 84GB",
          "tools": true,
          "reasoning": false
        },
        "qwen3.6-coder-agent": {
          "name": "Qwen3.6-27B Dense  (Q6, fast 21GB fallback) - 84 GB?",
          "tools": true,
          "reasoning": true,
          "options": {
            "think": false
          }
        },
        "qwen3.6:27b-dense-bf16": {
          "name": "Qwen3.6 27B Dense bf16 (Dense) - 54GB + 256K context",
          "tools": true,
          "reasoning": false
        },
        "qwen3-coder-agent": {
          "name": "Qwen3-Coder-Next 80B-A3B  (Q8, MoE, fast) - 84GB",
          "tools": true,
          "reasoning": false
        },
        "qwen3.6-coding-nothink": {
          "name": "Qwen3.6 35B A3B Coding BF16 — primary coding - 70 GB",
          "tools": true,
          "reasoning": true,
          "options": {
            "think": false
          }
        },
        "qwen3.6-coding-think": {
          "name": "Qwen3.6 35B A3B Coding BF16 — thinking - 70 GB",
          "tools": true,
          "reasoning": true,
          "options": {
            "think": true
          }
        },
        "qwen3.6:35b-a3b-mlx-bf16": {
          "name": "Qwen3.6 35B A3B MLX BF16 — general fallback - 70 GB",
          "tools": true,
          "reasoning": true,
          "options": {
            "think": false
          }
        },
        "qwen3.6:35b-a3b-bf16": {
          "name": "Qwen3.6 35B A3B BF16 — baseline - 71 GB",
          "tools": true,
          "reasoning": true,
          "options": {
            "think": false
          }
        },
        "qwen3.6-coder-agent-think": {
          "name": "Qwen3.6-27B Dense  (Q6, thinking ON — hard problems)",
          "tools": true,
          "reasoning": true,
          "options": {
            "think": true
          }
        },
        "gemma4:31b-it-bf16": {
          "name": "Gemma4 31b IT BF16 — general fallback - 62GB",
          "tools": true,
          "reasoning": true,
          "options": {
            "think": true
          }
        }
      }
    }
  },
  "model": "ollama/qwen3.6:35b-a3b-coding-bf16",
  "permission": {
    "websearch": "allow",
    "webfetch": "allow",
    "bash": {
      "ls": "allow",
      "find": "allow",
      "grep": "allow",
      "rg": "allow",
      "cat": "ask",
      "git": "ask",
      "gradle": "ask",
      "./gradlew": "ask",
      "rm": "deny",
      "curl": "ask",
      "wget": "ask"
    }
  }
}
