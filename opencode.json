{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "ornith:35b-fp16-code": {
          "name": "1. Primary coding — Ornith 35B BF16",
          "options": {
            "temperature": 0.18,
            "top_k": 20,
            "top_p": 0.85,
            "num_ctx": 65536,
            "num_predict": 8192,
            "repeat_penalty": 1.05
          }
        },
        "ornith:35b-q8-code": {
          "name": "2. Fast coding fallback — Ornith 35B Q8",
          "options": {
            "temperature": 0.2,
            "top_k": 20,
            "top_p": 0.85,
            "num_ctx": 65536,
            "num_predict": 8192,
            "repeat_penalty": 1.05
          }
        },
        "qwen3.6:27B-bf16-coder-agent": {
          "name": "3. Dense fallback — Qwen3.6 27B BF16"
        },
        "ornith:35b-fp16-plan": {
          "name": "4. Planning — Ornith 35B BF16",
          "options": {
            "temperature": 0.32,
            "top_k": 20,
            "top_p": 0.9,
            "num_ctx": 131072,
            "num_predict": 4096,
            "repeat_penalty": 1.05
          }
        },
        "qwen3-q8-large-agent": {
          "name": "5. Planning alternative — Qwen3 Large Agent Q8"
        },
        "llama3.3:70b-q8-prose": {
          "name": "6. General chat — Llama 3.3 70B Q8"
        },
        "ornith:9b-q4-complete": {
          "name": "7. Code completion — Ornith 9B",
          "options": {
            "temperature": 0.1,
            "top_k": 20,
            "top_p": 0.8,
            "num_ctx": 8192,
            "num_predict": 256,
            "repeat_penalty": 1.03
          }
        }
      }
    }
  },
  "model": "ollama/ornith:35b-fp16-code",
  "small_model": "ollama/ornith:9b-q4-fast-code",
  "permission": {
    "websearch": "allow",
    "webfetch": "allow",
    "bash": {
      "ls": "allow",
      "find": "allow",
      "grep": "allow",
      "rg": "allow",
      "cat": "ask",
      "git": "ask",
      "gradle": "ask",
      "./gradlew": "ask",
      "rm": "deny",
      "curl": "ask",
      "wget": "ask"
    }
  }
}