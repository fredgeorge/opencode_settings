{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3-coder-agent": {
          "name": "Qwen3-Coder-Next 80B-A3B  (Q8, MoE, fast)",
          "tools": true,
          "reasoning": false
        },
        "qwen3.6-coding-nothink": {
          "name": "Qwen3.6 35B A3B Coding BF16 — primary coding",
          "tools": true,
          "reasoning": true,
          "options": {
            "think": false
          }
        },
        "qwen3.6-coding-think": {
          "name": "Qwen3.6 35B A3B Coding BF16 — thinking",
          "tools": true,
          "reasoning": true,
          "options": {
            "think": true
          }
        },
        "qwen3.6:35b-a3b-mlx-bf16": {
          "name": "Qwen3.6 35B A3B MLX BF16 — general fallback",
          "tools": true,
          "reasoning": true,
          "options": {
            "think": false
          }
        },
        "qwen3.6:35b-a3b-bf16": {
          "name": "Qwen3.6 35B A3B BF16 — baseline",
          "tools": true,
          "reasoning": true,
          "options": {
            "think": false
          }
        },
        "qwen3.6-coder-agent": {
          "name": "Qwen3.6-27B Dense  (Q6, thinking off)",
          "tools": true,
          "reasoning": true,
          "options": {
            "think": false
          }
        },
        "qwen3.6-coder-agent-think": {
          "name": "Qwen3.6-27B Dense  (Q6, thinking ON — hard problems)",
          "tools": true,
          "reasoning": true,
          "options": {
            "think": true
          }
        }
      }
    }
  },
  "model": "ollama/qwen3.6:35b-a3b-coding-bf16",
  "permission": {
    "websearch": "allow",
    "webfetch": "allow",
    "bash": {
      "ls": "allow",
      "find": "allow",
      "grep": "allow",
      "rg": "allow",
      "cat": "ask",
      "git": "ask",
      "gradle": "ask",
      "./gradlew": "ask",
      "rm": "deny",
      "curl": "ask",
      "wget": "ask"
    }
  }
}
