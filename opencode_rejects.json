{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "ornith:35b-Q8_0-chat": {
          "name": "Ornith 35B Q8 Chat (technical chat fallback) - Q8_0",
          "tools": true,
          "reasoning": false,
          "options": {
            "temperature": 0.55,
            "top_k": 30,
            "top_p": 0.95,
            "num_ctx": 32768,
            "num_predict": 4096,
            "repeat_penalty": 1.05
          }
        },
        "qwen3.6-27B-bf16-think": {
          "name": "Qwen3.6 27B bf16 Think (planning, debugging, architecture) - 54GB, 128 CTX, 32K predict",
          "tools": true,
          "reasoning": false
        },
        "ornith:35b-Q4_K_M-plan": {
          "name": "Ornith 35B Plan (Q4_K_M, architecture, debugging, repo reasoning) - ~35B",
          "tools": true,
          "reasoning": true,
          "options": {
            "temperature": 0.35,
            "top_k": 20,
            "top_p": 0.9,
            "num_ctx": 65536,
            "num_predict": 4096,
            "repeat_penalty": 1.05
          }
        },
        "qwen3.6:27B": {
          "name": "Qwen3.6 27B Q4 (Q4, vision, fast - 17 GB",
          "tools": true,
          "reasoning": false,
          "options": {
            "temperature": 0.4,
            "top_k": 20,
            "top_p": 0.95,
            "min_p": 0,
            "num_ctx": 65536,
            "num_predict": 8192,
            "repeat_penalty": 1.05,
            "presence_penalty": 0
          }
        },
        "qwen3.6-coder-agent": {
          "name": "Qwen3.6-27B Dense  (Q6, fast 21GB fallback) - 84 GB?",
          "tools": true,
          "reasoning": true,
          "options": {
            "think": false
          }
        },
        "qwen3-coder-agent": {
          "name": "Qwen3-Coder-Next 80B-A3B  (Q8, MoE, fast) - 84GB",
          "tools": true,
          "reasoning": false
        },
        "qwen3.6-coding-nothink": {
          "name": "Qwen3.6 35B A3B Coding BF16 — primary coding - 70 GB",
          "tools": true,
          "reasoning": true,
          "options": {
            "think": false
          }
        },
        "qwen3.6-coding-think": {
          "name": "Qwen3.6 35B A3B Coding BF16 — thinking - 70 GB",
          "tools": true,
          "reasoning": true,
          "options": {
            "think": true
          }
        },
        "qwen3.6:35b-a3b-mlx-bf16": {
          "name": "Qwen3.6 35B A3B MLX BF16 — general fallback - 70 GB",
          "tools": true,
          "reasoning": true,
          "options": {
            "think": false
          }
        },
        "qwen3.6:35b-a3b-bf16": {
          "name": "Qwen3.6 35B A3B BF16 — baseline - 71 GB",
          "tools": true,
          "reasoning": true,
          "options": {
            "think": false
          }
        },
        "qwen3.6-coder-agent-think": {
          "name": "Qwen3.6-27B Dense  (Q6, thinking ON — hard problems)",
          "tools": true,
          "reasoning": true,
          "options": {
            "think": true
          }
        },
        "gemma4:31b-it-bf16": {
          "name": "Gemma4 31b IT BF16 — general fallback - 62GB",
          "tools": true,
          "reasoning": true,
          "options": {
            "think": true
          }
        }
      }
    }
  },
  "model": "ornith:35b-Q8_0-code",
  "permission": {
    "websearch": "allow",
    "webfetch": "allow",
    "bash": {
      "ls": "allow",
      "find": "allow",
      "grep": "allow",
      "rg": "allow",
      "cat": "ask",
      "git": "ask",
      "gradle": "ask",
      "./gradlew": "ask",
      "rm": "deny",
      "curl": "ask",
      "wget": "ask"
    }
  }
}